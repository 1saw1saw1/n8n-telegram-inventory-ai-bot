        "jsCode": "const data = items.map(item => item.json);\n\n// ищем активный режим поиска\nconst searchSession = data.find(item =>\n  item.state === \"search_product\"\n);\n\n// берём сообщение из Telegram\nconst telegram = data.find(item =>\n  item.message?.text\n);\n\nreturn [\n  {\n    json: {\n      state: searchSession?.state || null,\n      query: telegram?.message?.text || null,\n      chat_id: telegram?.message?.chat?.id || null\n    }\n  }\n];"
      },
