    {
      "parameters": {
        "jsCode": "// Отримуємо вхідні дані\nconst input = items[0].json;\nconst products = input.data;\n\n// Фільтруємо: показуємо тільки те, що закінчилося (0) або закінчиться через 7 днів\nconst critical = products.filter(item => item.current_stock <= 0 || item.days_left <= 7);\n\n// Перевірка, чи є що показувати\nif (critical.length === 0) {\n  return { json: { text: \"✅ На даний момент критичних залишків немає, все в нормі!\" } };\n}\n\n// Формуємо повідомлення\nlet message = \"🚨 *Критичні залишки (терміново до замовлення):*\\n\\n\";\n\ncritical.forEach(item => {\n  const stockInfo = item.current_stock <= 0 ? \"🔴 НЕМАЄ\" : `${item.current_stock} шт.`;\n  const statusInfo = item.current_stock <= 0 ? \"Закінчився\" : `закінчиться через ${item.days_left} дн.`;\n  const dailySales = (item.avg_monthly_sales / 30).toFixed(1);\n\n  message += `📦 *${item.name}*\\n` + \n             `▫️ Залишок: ${stockInfo}\\n` +\n             `▫️ Статус: ${statusInfo}\\n` +\n             `▫️ Продажі: ${dailySales} шт./день\\n\\n`;\n});\n\n// Замість return { json: { text: message } };\n// Використовуйте це:\nreturn {\n  json: {\n    text: message,\n    // Ми явно передаємо Chat ID далі, щоб нода Telegram його бачила\n    chatId: items[0].json.message?.chat.id || items[0].json.callback_query?.message.chat.id\n  }\n};"
      },
