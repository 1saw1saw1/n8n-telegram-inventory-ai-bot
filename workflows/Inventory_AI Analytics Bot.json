    {
      "parameters": {
        "jsCode": "// 1-4. (Весь ваш код получения данных, периодов и сбора статистики оставляем как есть)\nconst productsRaw = $('HTTP Request1').first()?.json;\nconst salesRaw = $('HTTP Request').first()?.json;\n\nlet products = [];\nif (productsRaw) {\n    if (Array.isArray(productsRaw)) products = productsRaw;\n    else if (Array.isArray(productsRaw.data)) products = productsRaw.data;\n    else if (productsRaw.products && Array.isArray(productsRaw.products.data)) products = productsRaw.products.data;\n    else if (Array.isArray(productsRaw.products)) products = productsRaw.products;\n}\n\nconst sales = Array.isArray(salesRaw?.data) ? salesRaw.data : (Array.isArray(salesRaw) ? salesRaw : []);\n\nif (products.length === 0) return [{ json: { data: [] } }];\n\nconst SHORT_DAYS = 30;\nconst LONG_DAYS = 365;\n\nfunction periodStart(days) {\n    const start = new Date();\n    start.setHours(0, 0, 0, 0);\n    start.setDate(start.getDate() - days);\n    return start;\n}\n\nconst start30 = periodStart(SHORT_DAYS);\nconst start365 = periodStart(LONG_DAYS);\n\nfunction parseDateIdent(dateIdent) {\n    const s = String(dateIdent ?? '').trim();\n    if (!/^\\d{8}$/.test(s)) return null;\n    return new Date(Number(s.slice(0, 4)), Number(s.slice(4, 6)) - 1, Number(s.slice(6, 8)));\n}\n\nfunction getOrderDate(order) {\n    const ts = Number(order.purchase_date);\n    if (Number.isFinite(ts) && ts > 0) return new Date(ts * 1000);\n    return parseDateIdent(order.date_ident);\n}\n\nconst salesMap30 = {};\nconst salesMap365 = {};\n\nfor (const order of sales) {\n    const orderDate = getOrderDate(order);\n    if (!orderDate || !Array.isArray(order.items)) continue;\n    for (const item of order.items) {\n        if (Number(item.is_refund) === 1) continue;\n        const productId = String(item.product_id);\n        const qty = Number(item.quantity);\n        if (!productId || !Number.isFinite(qty) || qty <= 0) continue;\n        if (orderDate >= start365) salesMap365[productId] = (salesMap365[productId] || 0) + qty;\n        if (orderDate >= start30) salesMap30[productId] = (salesMap30[productId] || 0) + qty;\n    }\n}\n\n// 5. Обработка товаров\nconst processedProducts = products\n    .filter(prod => prod && typeof prod === 'object' && Object.keys(prod).length > 0)\n    .map((prod) => {\n        let stockObj = Array.isArray(prod.stock) ? (prod.stock[0] || {}) : (prod.stock || {});\n        const pid = String(prod.id ?? 'unknown');\n        const s30 = Math.round(salesMap30[pid] || 0);\n        const s365 = Math.round(salesMap365[pid] || 0);\n        const currentStock = Math.round(Number(stockObj.quantity ?? stockObj.instock ?? 0));\n        const dailySales = s30 / SHORT_DAYS;\n\n        return {\n            id: prod.id,\n            sku: prod.sku || 'N/A',\n            name: prod.name || 'Без названия',\n            category: prod.category?.[0]?.name || 'No Category',\n            current_stock: currentStock,\n            net_cost: Number(stockObj.net_price ?? 0),\n            sales_volume_30_days: s30,\n            sales_volume_365_days: s365,\n            avg_monthly_sales: Math.round(s365 / 12),\n            days_left: dailySales > 0 ? Math.round(currentStock / dailySales) : 999,\n        };\n    });\n\n// 6 & 7. Исправленная логика: принудительная уникализация\nconst finalData = processedProducts.map((item, index) => {\n    // 1. Убираем id и category, так как их нет в базе\n    const { id, category, ...rest } = item;\n    \n    // 2. Если SKU равен N/A, превращаем его в уникальный, добавляя ID или индекс\n    // Использование ID из оригинального товара делает SKU уникальным на 100%\n    if (rest.sku === 'N/A' || !rest.sku) {\n        rest.sku = `NA_${id || index}`; \n    }\n    \n    return rest;\n});\n\nreturn [{ json: { data: finalData } }];"
      },
