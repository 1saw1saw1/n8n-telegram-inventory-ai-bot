        "jsCode": "const items = $('HTTP Request7').all();\nconst products = items.map(i => i.json);\n\n// Фильтруем товары, которые \"Важные\" (имеют продажи) и \"Скоро закончатся\" (дефицитные)\nconst replenishmentList = products.filter(item => {\n    const avgMonthly = Number(item.avg_monthly_sales ?? 0);\n    const daysLeft = Number(item.days_left ?? 0);\n   \n    \n    // Условие: продается >= 1 в месяц И запас менее 10 дней И остаток > 0\n    return avgMonthly >= 1 && daysLeft < 10;\n});\n\n// Возвращаем результат\nreturn replenishmentList.map(item => ({ json: item }));"
      },
