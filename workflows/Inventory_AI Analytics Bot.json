    {
      "parameters": {
        "jsCode": "// 1. Получаем входные данные\nconst items = $('HTTP Request6').all(); // Используем .all() для получения всех 56 объектов\nconst products = items.map(i => i.json);\n\nconsole.log('Всего получено товаров:', products.length);\n\n// 2. Фильтруем (делаем условия максимально простыми)\nconst outsiders = products.filter(item => {\n    // Явно преобразуем в числа, чтобы избежать сравнения строк \"0\" и числа 0\n    const sales = parseInt(item.sales_volume_365_days);\n    const stock = parseInt(item.current_stock);\n    \n    // Условие:\n    // 1. Продаж ровно 0\n    // 2. И товар есть на складе (> 0)\n    return  stock >= 0 && sales < 3;\n});\n\nconsole.log('Найдено аутсайдеров:', outsiders.length);\n\n// 3. Возвращаем результат\nreturn outsiders.map(item => ({ json: item }));"
